{
  "schemaVersion": 1,
  "id": "${mod_id}",
  "version": "${version}",
  "name": "${mod_name}",
  "description": "${description}",
  "authors": ["${mod_author}"],
  "contact": {},
  "license": "${license}",
  "environment": "*",
  "entrypoints": {
    "main": ["com.betternautilus.fabric.BetterNautilusFabric"],
    "client": ["com.betternautilus.fabric.BetterNautilusFabricClient"]
  },
  "mixins": [
    "betternautilus.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=${fabric_loader_version}",
    "fabric-api": "*",
    "minecraft": "${minecraft_version_range}"
  }
}
